#!/bin/bash
# ====================================================================
# Custom AutoConfig-Safe Environment Extensions for Oracle Reports
# Shared by tagtuner (GitHub Release)
#
# INSTRUCTIONS:
# Place this file as custom<CONTEXT_NAME>.env inside:
# $INST_TOP/appl/admin/ (e.g. /u01/oracle/inst/apps/PROD_host/appl/admin/)
# Set execute permissions: chmod 755 custom<CONTEXT_NAME>.env
# ====================================================================

# Specify ORACLE_HOME for 10.1.2 Middleware
export TK_ADMIN=$ORACLE_HOME/guicommon/tk/admin
export REPORTS_ENHANCED_SUBSET=YES
export REPORTS_PATH=$TK_ADMIN:$REPORTS_PATH

echo "[CUSTOM_ENV] Cyrillic font subsetting variables successfully loaded."
